rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Soldiers: 
    // Anyone can read profiles (needed for matches)
    // Only the owner can create/update their profile
    match /soldiers/{soldierId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == soldierId;
    }
    
    // Families: 
    // Anyone can read profiles
    // Only the owner can create/update their profile
    match /families/{familyId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == familyId;
    }

    // Soldier Hosting Searches (Requests):
    // Anyone can read (so families can see them)
    // The soldier can fully update their own request.
    // Any authenticated user (e.g. a family canceling their hosting) may only
    // reset is_match and update temporarily_banned_families — nothing else.
    match /soldier_hosting_searches/{searchId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.soldier_id;
      allow delete: if request.auth != null && request.auth.uid == resource.data.soldier_id;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.soldier_id
        ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['is_match', 'temporarily_banned_families'])
      );
    }

    // Family Hostings (Offers):
    // Anyone can read (so soldiers can see them)
    // Any authenticated user can create or update (family_id is set by the app)
    match /family_hostings/{hostingId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Active Matches:
    // Requires authentication to read or modify.
    // In a production app, you might restrict this further 
    // so only the involved soldier and family can read/update.
    match /active_matches/{matchId} {
      allow read, write: if request.auth != null;
    }

    // Rematches:
    match /rematches/{rematchId} {
      allow read, write: if request.auth != null;
    }

    // Archive collections — written only by Cloud Functions (admin SDK bypasses rules).
    // Authenticated users can read their own history.
    match /active_match_archive/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions only
    }

    match /soldier_hosting_searches_archive/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /family_hostings_archive/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
